{
  "name": "sprout",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "sprout": "src/host/cli.ts"
  },
  "scripts": {
    "check": "biome check --write .",
    "check:ci": "bun run lint && bun run typecheck && bun run check:architecture && bun run test:unit:parallel",
    "check:deep": "bun run check:ci && bun run deadcode && bun run deps:cycles",
    "check:architecture": "bun run check:host-guardrails && bun test test/architecture",
    "check:host-guardrails": "bash scripts/check-host-session-controller-boundaries.sh",
    "deadcode": "bun run deadcode:report",
    "deadcode:report": "bun run deadcode:report:deps && bun run deadcode:report:exports",
    "deadcode:report:deps": "bunx knip -c knip.root.json --include dependencies,unresolved --reporter compact --no-exit-code && bunx knip --directory web -c knip.json --include dependencies,unresolved --reporter compact --no-exit-code",
    "deadcode:report:exports": "bunx knip -c knip.cross.json --include exports --reporter compact --no-exit-code",
    "deadcode:runtime": "bunx knip -c knip.root.json --include unresolved --reporter compact && bunx knip --directory web -c knip.json --include unresolved --reporter compact && bun run deadcode:trace",
    "deadcode:strict": "bun run deadcode:runtime",
    "deadcode:trace": "bash scripts/check-knip-traces.sh",
    "deps:cycles": "bash scripts/check-deps-cycles.sh",
    "deps:cycles:strict": "CYCLE_STRICT=1 bash scripts/check-deps-cycles.sh",
    "hooks:install": "bash scripts/install-hooks.sh",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit --project web/tsconfig.json",
    "test": "bun test",
    "test:flake": "bash scripts/test-flake.sh bun run test:unit:parallel",
    "test:unit": "bash scripts/run-tests-from-list.sh scripts/test-unit-files.sh",
    "test:unit:parallel": "bash scripts/run-tests-parallel-from-list.sh scripts/test-unit-files.sh",
    "test:integration": "VCR_MODE=replay bash scripts/run-tests-from-list.sh scripts/test-integration-files.sh",
    "test:integration:record": "VCR_MODE=record bash scripts/run-tests-from-list.sh scripts/test-integration-files.sh",
    "test:integration:live": "VCR_MODE=off bash scripts/run-tests-from-list.sh scripts/test-integration-files.sh",
    "test:all": "bun test",
    "test:parallel": "bash scripts/test-parallel.sh",
    "test:watch": "bun test --watch",
    "postinstall": "cd web && bun install",
    "precommit": "bun run check && bun run typecheck && bun run test:unit:parallel",
    "web:build": "cd web && bun run build",
    "web:dev": "cd web && bun run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "ink-testing-library": "^4.0.0",
    "knip": "^5.85.0",
    "madge": "^8.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.42.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "ink": "^6.8.0",
    "ink-markdown-es": "^1.4.0",
    "ink-shiki-code": "^1.0.0",
    "openai": "^6.22.0",
    "react": "^19.2.4",
    "yaml": "^2.8.2"
  }
}
