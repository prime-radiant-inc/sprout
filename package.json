{
  "name": "sprout",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "sprout": "src/host/cli.ts"
  },
  "scripts": {
    "check": "biome check --write .",
    "check:ci": "bun run lint && bun run typecheck && bun run check:architecture && bun run test:unit:parallel",
    "check:architecture": "bun run check:host-guardrails && bun test test/architecture",
    "check:host-guardrails": "bash scripts/check-host-session-controller-boundaries.sh",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit --project web/tsconfig.json",
    "test": "bun test",
    "test:unit": "bun test $(bash scripts/test-unit-files.sh)",
    "test:unit:parallel": "bash scripts/test-parallel.sh $(bash scripts/test-unit-files.sh)",
    "test:integration": "VCR_MODE=replay bun test $(bash scripts/test-integration-files.sh)",
    "test:integration:record": "VCR_MODE=record bun test $(bash scripts/test-integration-files.sh)",
    "test:integration:live": "VCR_MODE=off bun test $(bash scripts/test-integration-files.sh)",
    "test:all": "bun test",
    "test:parallel": "bash scripts/test-parallel.sh",
    "test:watch": "bun test --watch",
    "precommit": "bun run check && bun run typecheck && bun run test:unit:parallel",
    "web:build": "cd web && bun run build",
    "web:dev": "cd web && bun run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "ink-testing-library": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.42.0",
    "dotenv": "^17.3.1",
    "highlight.js": "^11.11.1",
    "ink": "^6.8.0",
    "ink-markdown-es": "^1.4.0",
    "ink-shiki-code": "^1.0.0",
    "isomorphic-dompurify": "^3.0.0",
    "marked": "^15.0.12",
    "openai": "^6.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.2"
  }
}
